<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- FOCUS -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/bg"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="2dp"
                android:color="@color/black"/>
            <padding
                android:left="14dp"
                android:top="12dp"
                android:right="14dp"
                android:bottom="12dp"/>
        </shape>
    </item>

    <!-- NORMAL -->
    <item>
        <shape>
            <solid android:color="@color/bg"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="1dp"
                android:color="@color/black"/>
            <padding
                android:left="14dp"
                android:top="12dp"
                android:right="14dp"
                android:bottom="12dp"/>
        </shape>
    </item>

</selector>
