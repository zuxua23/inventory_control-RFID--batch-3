<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/white"/>
            <corners android:radius="20dp"/>
            <stroke
                android:width="2dp"
                android:color="@color/blue_theme"/>
            <padding
                android:left="10dp"
                android:top="0dp"
                android:right="10dp"
                android:bottom="0dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/white"/>
            <corners android:radius="18dp"/>
            <stroke
                android:width="1dp"
                android:color="@color/blue_theme"/>
            <padding
                android:left="10dp"
                android:top="8dp"
                android:right="10dp"
                android:bottom="8dp"/>
        </shape>
    </item>

</selector>
