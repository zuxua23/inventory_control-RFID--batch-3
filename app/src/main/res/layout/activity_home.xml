<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/blue_theme">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/account_icon"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_user_profile_menu" />

        <ImageButton
            android:id="@+id/btnSyncData"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_popup_sync"
            app:tint="@color/white"
            android:contentDescription="@string/descsync_offline_data" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/ivProfile"
            android:layout_toStartOf="@id/btnSyncData"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/textViewNamaOperator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/raleway_bold"
                android:text="@string/greeting_welcome"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textViewRoleOperator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/raleway_regular"
                android:text="@string/geeting_role"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                tools:ignore="TextContrastCheck" />
        </LinearLayout>
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:background="@drawable/bg_white_rounded_top"
        app:cardElevation="15dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/blue_theme"
                app:cardElevation="0dp">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:clipToPadding="false"
                    tools:ignore="UselessParent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_menu"
                            android:paddingStart="6dp"
                            android:paddingTop="4dp"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:fontFamily="@font/raleway_extra_bold"
                            android:layout_marginBottom="16dp"
                            tools:ignore="RtlSymmetry" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:padding="8dp">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:cardCornerRadius="16dp"
                                    app:cardBackgroundColor="@android:color/white"
                                    app:cardElevation="2dp">

                                    <LinearLayout
                                        android:id="@+id/ButtonStockIn"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:paddingVertical="20dp"
                                        android:paddingHorizontal="12dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:foreground="?android:attr/selectableItemBackground">

                                        <ImageView
                                            android:layout_width="64dp"
                                            android:layout_height="64dp"
                                            android:src="@drawable/stock_in_icon"
                                            android:importantForAccessibility="no" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="12dp"
                                            android:fontFamily="@font/raleway_bold"
                                            android:text="@string/menu_stock_in"
                                            android:textColor="#388E3C"
                                            android:textSize="14sp"
                                            android:gravity="center"
                                            android:minLines="2"
                                            android:textAlignment="center"/>
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:padding="8dp">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:cardCornerRadius="16dp"
                                    app:cardBackgroundColor="@android:color/white"
                                    app:cardElevation="2dp">

                                    <LinearLayout
                                        android:id="@+id/ButtonStockPreparation"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:paddingVertical="20dp"
                                        android:paddingHorizontal="12dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:foreground="?android:attr/selectableItemBackground">

                                        <ImageView
                                            android:layout_width="64dp"
                                            android:layout_height="64dp"
                                            android:src="@drawable/stock_preparation_icon"
                                            android:importantForAccessibility="no" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="12dp"
                                            android:fontFamily="@font/raleway_bold"
                                            android:text="@string/menu_stock_preparation"
                                            android:textColor="#F57C00"
                                            android:textSize="14sp"
                                            android:gravity="center"
                                            android:minLines="2"
                                            android:textAlignment="center"/>
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:padding="8dp">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:cardCornerRadius="16dp"
                                    app:cardBackgroundColor="@android:color/white"
                                    app:cardElevation="2dp">

                                    <LinearLayout
                                        android:id="@+id/ButtonTagRegis"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:paddingVertical="20dp"
                                        android:paddingHorizontal="12dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:foreground="?android:attr/selectableItemBackground">

                                        <ImageView
                                            android:layout_width="64dp"
                                            android:layout_height="64dp"
                                            android:src="@drawable/ic_tag"
                                            android:importantForAccessibility="no" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="12dp"
                                            android:fontFamily="@font/raleway_bold"
                                            android:text="@string/menu_tag_registration"
                                            android:textColor="#12538D"
                                            android:textSize="14sp"
                                            android:gravity="center"
                                            android:minLines="2"
                                            android:textAlignment="center"/>
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:padding="8dp">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:cardCornerRadius="16dp"
                                    app:cardBackgroundColor="@android:color/white"
                                    app:cardElevation="2dp">

                                    <LinearLayout
                                        android:id="@+id/ButtonStockTaking"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:paddingVertical="20dp"
                                        android:paddingHorizontal="12dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:foreground="?android:attr/selectableItemBackground">

                                        <ImageView
                                            android:layout_width="64dp"
                                            android:layout_height="64dp"
                                            android:src="@drawable/stock_taking_icon"
                                            android:importantForAccessibility="no" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="12dp"
                                            android:fontFamily="@font/raleway_bold"
                                            android:text="@string/menu_stock_taking"
                                            android:textColor="#D32F2F"
                                            android:textSize="14sp"
                                            android:gravity="center"
                                            android:minLines="2"
                                            android:textAlignment="center"/>
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginBottom="16dp">

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0.5"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:padding="8dp">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:cardCornerRadius="16dp"
                                    app:cardBackgroundColor="@android:color/white"
                                    app:cardElevation="2dp">

                                    <LinearLayout
                                        android:id="@+id/ButtonSearchItem"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:paddingVertical="20dp"
                                        android:paddingHorizontal="12dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:foreground="?android:attr/selectableItemBackground">

                                        <ImageView
                                            android:layout_width="64dp"
                                            android:layout_height="64dp"
                                            android:src="@drawable/seacrh_item_icon"
                                            android:importantForAccessibility="no" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="12dp"
                                            android:fontFamily="@font/raleway_bold"
                                            android:text="@string/menu_search_item"
                                            android:textColor="#0288D1"
                                            android:textSize="14sp"
                                            android:gravity="center"
                                            android:minLines="2"
                                            android:textAlignment="center"/>
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0.5"/>
                        </LinearLayout>

                    </LinearLayout>
                </ScrollView>
            </androidx.cardview.widget.CardView>
    </FrameLayout>
</LinearLayout>