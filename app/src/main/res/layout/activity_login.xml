<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:paddingTop="10dp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_centerInParent="true"
                android:text="@string/Title_login"
                android:textColor="#7A7C7D"
                android:fontFamily="@font/raleway_extra_bold"
                android:textSize="20sp"
                android:gravity="center"
                android:textStyle="bold"
                tools:ignore="RelativeOverlap" />

            <ImageButton
                android:id="@+id/btnSetting"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_setting_24"
                android:background="@drawable/bg_btn_setting"
                android:stateListAnimator="@null"
                app:tint="#7A7C7D"
                android:contentDescription="@string/desc_settings_button" />

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.01dp"
            android:background="#7A7C7D" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_header"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">
            <Space
                android:layout_width="wrap_content"
                android:layout_height="10dp"/>
            <ImageView
                android:layout_width="160dp"
                android:layout_height="132dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#20FFFFFF"
                android:padding="16dp"
                android:src="@drawable/ic_box_24"
                app:tint="@color/blue_theme"
                android:importantForAccessibility="no" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/blue_theme"
                android:elevation="6dp"
                app:cardCornerRadius="20dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="32dp"
                        tools:ignore="UselessParent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="@string/title_welcome_back"
                            android:fontFamily="@font/raleway_semi_bold"
                            android:textColor="@color/bg"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:text="@string/subtitle_sign_in"
                            android:textColor="@color/bg"
                            android:fontFamily="@font/raleway_light"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="@string/label_username"
                            android:fontFamily="@font/raleway_bold"
                            android:textColor="@color/bg"
                            android:textSize="12sp"
                            tools:ignore="TextContrastCheck"/>

                        <EditText
                            android:id="@+id/etUsername"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginBottom="20dp"
                            android:background="@drawable/bg_edit_text"
                            android:drawablePadding="12dp"
                            android:hint="@string/hint_username"
                            android:textSize="14sp"
                            android:fontFamily="@font/raleway_regular"
                            android:imeOptions="actionNext"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/black"
                            android:paddingHorizontal="16dp"
                            android:textColorHint="@color/text_grey"
                            android:autofillHints="username" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="@string/label_password"
                            android:fontFamily="@font/raleway_bold"
                            android:textColor="@color/bg"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:ignore="TextContrastCheck"/>

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:fontFamily="@font/raleway_regular"
                            android:layout_marginBottom="32dp"
                            android:background="@drawable/bg_edit_text"
                            android:drawablePadding="12dp"
                            android:textSize="14sp"
                            android:hint="@string/hint_password"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="@color/black"
                            android:paddingHorizontal="16dp"
                            android:textColorHint="@color/text_grey"
                            android:autofillHints="password" />

                        <Button
                            android:id="@+id/btnLogin"
                            android:layout_width="150dp"
                            android:layout_height="50dp"
                            android:backgroundTint="@color/green_button"
                            android:text="@string/action_sign_in"
                            android:textAllCaps="false"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:fontFamily="@font/raleway_bold"
                            android:stateListAnimator="@null"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            app:cornerRadius="20dp"
                            tools:ignore="TextContrastCheck" />

                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>