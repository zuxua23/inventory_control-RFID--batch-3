<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_theme">

    <!-- Settings button (top-end) — also used for window insets via layout_header id -->
    <ImageButton
        android:id="@+id/btnSetting"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_setting"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        app:tint="@color/white"
        android:contentDescription="@string/desc_settings_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Hidden anchor for WindowInsets top padding (preserves inset handling) -->
    <View
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- App logo -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_box"
        app:tint="@color/white"
        android:importantForAccessibility="no"
        android:layout_marginBottom="14dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvAppName" />

    <!-- App name -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Title_login"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:fontFamily="@font/raleway_extra_bold"
        android:layout_marginBottom="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTagline" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_tagline"
        android:textColor="#B3FFFFFF"
        android:textSize="13sp"
        android:fontFamily="@font/raleway_regular"
        android:layout_marginBottom="36dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardLogin" />

    <!-- Login Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardBackgroundColor="@color/bg_white"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.58">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/title_welcome_back"
                android:fontFamily="@font/raleway_semi_bold"
                android:textColor="@color/blue_theme"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/subtitle_sign_in"
                android:textColor="@color/text_grey"
                android:fontFamily="@font/raleway_light"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/label_username"
                android:fontFamily="@font/raleway_bold"
                android:textColor="@color/text_dark"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_edit_text"
                android:drawablePadding="12dp"
                android:hint="@string/hint_username"
                android:textSize="14sp"
                android:fontFamily="@font/raleway_regular"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/black"
                android:paddingHorizontal="16dp"
                android:textColorHint="@color/text_grey"
                android:autofillHints="username" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/label_password"
                android:fontFamily="@font/raleway_bold"
                android:textColor="@color/text_dark"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:fontFamily="@font/raleway_regular"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_edit_text"
                android:drawablePadding="12dp"
                android:textSize="14sp"
                android:hint="@string/hint_password"
                android:imeOptions="actionDone"
                android:inputType="textPassword"
                android:maxLines="1"
                android:textColor="@color/black"
                android:paddingHorizontal="16dp"
                android:textColorHint="@color/text_grey"
                android:autofillHints="password" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="@color/green_button"
                android:text="@string/action_sign_in"
                android:textAllCaps="false"
                android:gravity="center"
                android:fontFamily="@font/raleway_bold"
                android:stateListAnimator="@null"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:cornerRadius="20dp"
                tools:ignore="TextContrastCheck" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- FAB Log -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFabLog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/warning_orange"
        app:strokeWidth="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Activity Log"
            android:src="@drawable/ic_log"
            app:fabSize="mini"
            app:tint="@color/warning_orange"
            app:backgroundTint="@color/white"
            app:borderWidth="0dp"
            app:elevation="0dp" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
