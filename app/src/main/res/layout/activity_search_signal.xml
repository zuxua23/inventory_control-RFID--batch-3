<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/bg_white">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:padding="8dp"
        android:src="@drawable/baseline_arrow_back_24"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardHeaderSearch"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="5dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/blue_theme"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="15dp">

            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Locating: [Item Name]"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginRight="10dp"
                android:fontFamily="@font/raleway_bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/cardSwitchContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardSwitchContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvModeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:fontFamily="@font/raleway_bold"
                        android:text="RFID"
                        android:textColor="@color/blue_theme"
                        android:textSize="14sp" />

                    <Switch
                        android:id="@+id/switchRfid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="48dp"
                        android:minHeight="32dp"
                        android:checked="true"
                        android:thumbTint="@color/switch_thumb_selector"
                        android:trackTint="@color/switch_track_selector"
                        tools:ignore="UseSwitchCompatOrMaterialXml" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="15dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardHeaderSearch"
        app:layout_constraintBottom_toTopOf="@id/btnStopSearch">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISTANCE"
                android:textColor="@color/blue_theme"
                android:fontFamily="@font/raleway_extra_bold"
                android:textSize="14sp"
                android:layout_marginBottom="30dp"/>

            <LinearLayout
                android:id="@+id/containerSignalBars"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:gravity="bottom|center_horizontal"
                android:orientation="horizontal">
                <View android:layout_width="15dp" android:layout_height="50dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="70dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="90dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="110dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="130dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="150dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="170dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="190dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="210dp" android:layout_margin="4dp" android:background="#E0E0E0" />
                <View android:layout_width="15dp" android:layout_height="230dp" android:layout_margin="4dp" android:background="#E0E0E0" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvRssiValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-00 dBm"
                android:layout_marginTop="20dp"
                android:textSize="22sp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="@color/blue_theme"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnStopSearch"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="20dp"
        android:text="STOP SEARCHING"
        android:backgroundTint="@color/merah"
        android:textColor="@color/white"
        android:fontFamily="@font/raleway_bold"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>