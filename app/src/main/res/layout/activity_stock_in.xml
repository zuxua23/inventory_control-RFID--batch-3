<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_theme"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:padding="12dp"
        android:src="@drawable/baseline_arrow_back_24"
        app:tint="@color/white"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/desc_back"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_stock_in"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:fontFamily="@font/raleway_bold"
        android:layout_marginStart="4dp"
        tools:ignore="TextContrastCheck"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack" />

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        tools:ignore="TouchTargetSizeCheck"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_rfid"
                android:textColor="@color/blue_theme"
                android:fontFamily="@font/raleway_bold"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <Switch
                android:id="@+id/switchRfid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:ignore="UseSwitchCompatOrMaterialXml,TouchTargetSizeCheck" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/whiteContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_white_rounded_top"
        android:elevation="10dp"
        android:outlineProvider="background"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutDropdowns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardLocation"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white"
                tools:ignore="TouchTargetSizeCheck">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:orientation="horizontal"
                    tools:ignore="UseCompoundDrawables">

                    <EditText
                        android:id="@+id/etLocation"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/hint_location"
                        android:textColor="@color/blue_theme"
                        android:textColorHint="#99000000"
                        android:fontFamily="@font/raleway_bold"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:inputType="text"
                        android:importantForAutofill="no"
                        android:imeOptions="actionDone"
                        tools:ignore="TouchTargetSizeCheck" />

                    <ImageView
                        android:id="@+id/ivLocationArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/outline_arrow_drop_down_24"
                        app:tint="@color/black"
                        android:contentDescription="@string/desc_location_arrow" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnPowerDropdown"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white"
                tools:ignore="TouchTargetSizeCheck">

                <TextView
                    android:id="@+id/tvPowerLevel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/label_power"
                    android:textColor="@color/blue_theme"
                    android:fontFamily="@font/raleway_bold"
                    android:textSize="14sp"
                    app:drawableEndCompat="@drawable/outline_arrow_drop_down_24"
                    app:drawableTint="@color/black"
                    android:drawablePadding="4dp"
                    android:paddingHorizontal="12dp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardScanned"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="#0077C0"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/layoutDropdowns">

            <EditText
                android:id="@+id/resultScan"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:background="@null"
                android:textColor="@android:color/transparent"
                android:cursorVisible="false"
                android:maxLines="1"
                android:inputType="textNoSuggestions"
                android:importantForAutofill="no"
                android:importantForAccessibility="no"
                tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck"
                android:imeOptions="actionDone" />

            <TextView
                android:id="@+id/tvScanned"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/label_scanned_count"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/raleway_bold"
                tools:ignore="TextContrastCheck" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardlistTag"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/cardScanned"
            app:layout_constraintBottom_toTopOf="@id/linearButton">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:id="@+id/llTabHeader"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_tab_button"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/btnListProduct"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="@string/tab_list_product"
                        android:textColor="@color/white"
                        android:fontFamily="@font/raleway_bold"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/blue_theme"
                        android:stateListAnimator="@null"
                        app:cornerRadius="12dp"
                        tools:ignore="TouchTargetSizeCheck,ButtonStyle" />

                    <Button
                        android:id="@+id/btnSumProduct"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="@string/tab_sum_product"
                        android:textColor="@color/blue_theme"
                        android:fontFamily="@font/raleway_bold"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/white"
                        android:stateListAnimator="@null"
                        app:cornerRadius="12dp"
                        tools:ignore="TouchTargetSizeCheck,ButtonStyle" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTags"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingBottom="10dp"
                    android:verticalScrollbarPosition="left"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_product" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/linearButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/merah"
                android:fontFamily="@font/raleway_bold"
                android:stateListAnimator="@null"
                android:text="@string/action_clear"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                tools:ignore="ButtonStyle" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="@font/raleway_bold"
                android:backgroundTint="@color/green_button"
                android:stateListAnimator="@null"
                android:text="@string/action_save"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                tools:ignore="TextContrastCheck,ButtonStyle" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>