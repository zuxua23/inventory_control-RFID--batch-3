<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_theme">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:contentDescription="@string/desc_back"
        android:padding="4dp"
        android:src="@drawable/baseline_arrow_back"
        app:tint="@color/white"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/menu_stock_preparation"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="@font/raleway_bold"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintEnd_toStartOf="@id/ivReaderBattery"
        app:layout_constraintBottom_toBottomOf="@id/btnBack" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardRfidSwitch"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack">

        <Switch
            android:id="@+id/switchRfid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp"
            android:text="@string/label_rfid"
            android:textStyle="bold"
            android:elevation="6dp"
            android:textColor="@color/blue_theme"
            android:fontFamily="@font/raleway_bold"
            android:textSize="14sp"
            android:switchPadding="8dp"
            tools:ignore="UseSwitchCompatOrMaterialXml, TouchTargetSizeCheck" />
    </androidx.cardview.widget.CardView>

    <ImageView
        android:id="@+id/ivReaderBattery"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_battery_indicator"
        android:visibility="gone"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@id/cardRfidSwitch"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <EditText
            android:id="@+id/resultScan"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:background="@null"
            android:textColor="@android:color/transparent"
            android:cursorVisible="false"
            android:maxLines="1"
            android:inputType="textNoSuggestions"
            android:importantForAutofill="no"
            android:importantForAccessibility="no"
            tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck"
            android:imeOptions="actionDone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/tvScanned"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/raleway_extra_bold"
                android:text="@string/label_scanned_count"
                android:textColor="@color/blue_theme"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvNoDo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="@font/raleway_bold"
                android:text="@string/label_no_do"
                android:textColor="@color/blue_theme"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDateDo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/raleway_bold"
                android:text="@string/label_date_do"
                android:textColor="@color/blue_theme"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/layoutDropdowns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/cardInfo">

        <Spinner
            android:id="@+id/spinnerLocation"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:elevation="6dp"
            android:background="@drawable/bg_spinner"
            android:popupBackground="@drawable/bg_spinner_dropdown"
            android:layout_margin="10dp"
            android:fontFamily="@font/raleway_bold"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerPower"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            android:elevation="6dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_spinner"
            android:popupBackground="@drawable/bg_spinner_dropdown"
            android:paddingHorizontal="12dp"
            android:fontFamily="@font/raleway_bold"
            android:textSize="14sp" />

    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/whiteContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_white_rounded_top"
        android:elevation="6dp"
        android:outlineProvider="background"
        app:layout_constraintTop_toBottomOf="@id/layoutDropdowns"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardlistTag"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomButtonsContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/llTabHeader"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_tab_button"
                    android:padding="4dp"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/btnListProduct"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:text="@string/tab_list_product"
                        android:textColor="@color/white"
                        android:fontFamily="@font/raleway_bold"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/blue_theme"
                        android:stateListAnimator="@null"
                        app:shapeAppearanceOverlay="@style/RoundedButtonLeft"
                        tools:ignore="TouchTargetSizeCheck,ButtonStyle" />

                    <Button
                        android:id="@+id/btnSumProduct"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:text="@string/tab_sum_product"
                        android:textColor="@color/blue_theme"
                        android:fontFamily="@font/raleway_bold"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/white"
                        android:stateListAnimator="@null"
                        app:shapeAppearanceOverlay="@style/RoundedButtonRight"
                        tools:ignore="TouchTargetSizeCheck,ButtonStyle" />

                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_margin="10dp"
                    android:layout_marginTop="4dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTags"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingBottom="10dp"
                        android:verticalScrollbarPosition="left"
                        android:scrollbars="vertical"
                        tools:listitem="@layout/item_product" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/bottomButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/red"
                android:fontFamily="@font/raleway_bold"
                android:stateListAnimator="@null"
                android:text="@string/action_clear"
                android:elevation="2dp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                tools:ignore="ButtonStyle" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="@font/raleway_bold"
                android:backgroundTint="@color/green_button"
                android:stateListAnimator="@null"
                android:text="@string/action_save"
                android:elevation="2dp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                tools:ignore="TextContrastCheck,ButtonStyle" />
        </LinearLayout>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFabLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeColor="#F57C00"
            app:strokeWidth="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/cardFabCamera">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Activity Log"
                android:src="@drawable/ic_log"
                app:tint="#F57C00"
                app:backgroundTint="@color/white"
                app:fabSize="mini"
                app:borderWidth="0dp"
                app:elevation="0dp" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFabCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeColor="#4B7BEC"
            app:strokeWidth="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomButtonsContainer">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabScanCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/desc_scan_camera"
                android:src="@drawable/ic_camera"
                app:tint="#4B7BEC"
                app:backgroundTint="@color/white"
                app:borderWidth="0dp"
                app:elevation="0dp" />

        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>