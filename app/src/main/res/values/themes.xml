<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Inventory_system_HT" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue_theme</item>
        <item name="colorPrimaryVariant">@color/blue_theme</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/blue_theme</item>

        <item name="android:windowBackground">@drawable/bg_launch</item>

        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>

        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/bg</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@android:color/transparent</item>
    </style>

    <style name="RoundedButtonLeft" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">13dp</item>
        <item name="cornerSizeBottomLeft">13dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="RoundedButtonRight" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeTopRight">13dp</item>
        <item name="cornerSizeBottomRight">13dp</item>
    </style>
</resources>